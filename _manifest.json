{
  "manifest_version": 2,
  "version": "1.3.1",
  "name": "机器人自回复硬拦截",
  "description": "通过 Planner/Replyer/发送前多层拦截阻止 MaiBot 回复自身消息。1.0-pre+ 用根目录；0.10–0.12 请用 legacy_maibot_0x/。配置缺字段自动回退默认值。",
  "author": {
    "name": "kumburovicbranko682-boop",
    "url": "https://github.com/kumburovicbranko682-boop"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/kumburovicbranko682-boop/maibot-self-reply-guard",
    "homepage": "https://github.com/kumburovicbranko682-boop/maibot-self-reply-guard",
    "documentation": "https://github.com/kumburovicbranko682-boop/maibot-self-reply-guard/blob/main/README.md",
    "issues": "https://github.com/kumburovicbranko682-boop/maibot-self-reply-guard/issues"
  },
  "host_application": {
    "min_version": "0.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.3.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "config.get",
    "message.get_by_id"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "display": {
    "icon": {
      "type": "lucide",
      "value": "shield-ban",
      "fallback": "shield-alert",
      "background": "#DC2626"
    }
  },
  "id": "github.kumburovicbranko682-boop.self-reply-guard"
}
